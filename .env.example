# ──────────────────────────────────────────────────────────────────────────
# MCCIA Intern OS — environment configuration
#
# Copy this to `.env.local` (gitignored — never commit real credentials) and
# fill in the values, then:
#
#   npm install
#   # create the schema: run supabase/schema.sql then supabase/seed.sql
#   # in the Supabase SQL editor
#   npm run dev
#
# ── Server-only (NOT exposed to the browser) ──────────────────────────────
# Supabase project URL (https://<ref>.supabase.co). Used by the /api serverless
# functions and the Vite dev middleware via the HTTPS data API.
SUPABASE_URL=

# The SECRET service-role key (Supabase → Settings → API), NOT the publishable
# key. It bypasses Row Level Security, so keep it secret — server-only.
SUPABASE_SERVICE_ROLE_KEY=

# A long random secret (e.g. `openssl rand -base64 32`) that signs the session
# token (JWT in an HttpOnly cookie). Keep it stable across deploys and secret.
# `BETTER_AUTH_SECRET` is still accepted as a fallback for older deployments.
AUTH_SECRET=
# ──────────────────────────────────────────────────────────────────────────
