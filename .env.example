# ──────────────────────────────────────────────────────────────────────────
# MCCIA Intern OS — environment configuration
#
# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored — NEVER commit real credentials.
#
# IMPORTANT — where each variable is used:
#   • Variables WITHOUT the `VITE_` prefix are SERVER-ONLY. They are read by the
#     Sheets proxy (Vite dev middleware locally, the serverless function in
#     production) and are NEVER bundled into the browser. The service-account
#     key lives here precisely so it stays off the client.
#   • Variables WITH the `VITE_` prefix ARE exposed to the browser bundle.
#     Put nothing secret in them.
# ──────────────────────────────────────────────────────────────────────────

# ── SERVER-ONLY (secret) ────────────────────────────────────────────────────

# The Google Cloud service-account JSON key, base64-encoded.
#
# How to produce it:
#   1. Google Cloud Console → APIs & Services → enable "Google Sheets API".
#   2. IAM & Admin → Service Accounts → create one → Keys → Add key → JSON.
#   3. Base64-encode the downloaded file:
#        macOS/Linux:  base64 -i service-account.json | tr -d '\n'
#        (or)          cat service-account.json | base64 | tr -d '\n'
#   4. Paste the single-line result below.
#   5. Open your Google Sheet → Share → add the service account's
#      `client_email` (…@…iam.gserviceaccount.com) as an Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=

# The spreadsheet ID — the long token in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
#
# OPTIONAL: the app is already linked to a default spreadsheet in
# `server/sheets-handler.ts` (DEFAULT_SHEETS_ID). Only set this to point the
# backend at a different sheet. The service account above must still be shared
# on whichever sheet is used.
SHEETS_ID=

# ── CLIENT (safe to expose) ──────────────────────────────────────────────────

# Where the browser sends Sheets proxy requests. Defaults to `/api/sheets`.
# Only change this if you host the proxy on a different path/origin.
# VITE_SHEETS_API_PATH=/api/sheets

# ──────────────────────────────────────────────────────────────────────────
# Expected spreadsheet tabs (first row = headers, matching these columns):
#
#   Companies:          id, createdAt, updatedAt, name, status, industry,
#                       website, contactName, contactEmail, contactPhone, notes
#   ConsultingSessions: id, createdAt, updatedAt, companyId, title, date,
#                       durationMinutes, outcome, summary, actionItems, notes
#   AppProjects:        id, createdAt, updatedAt, companyId, name, stage,
#                       progressPercent, repoUrl, liveUrl, startDate,
#                       targetLaunchDate, description, nextAction, blocker
#   SocialCreatives:    id, createdAt, updatedAt, companyId, title, platform,
#                       status, scheduledFor, caption, imageUrl, notes
#   FollowUps:          id, createdAt, updatedAt, companyId, title, status,
#                       dueDate, relatedType, relatedId, notes
# ──────────────────────────────────────────────────────────────────────────
