# ──────────────────────────────────────────────────────────────────────────
# MCCIA Intern OS — environment configuration
#
# Copy this to `.env.local` (gitignored — never commit real credentials) and
# fill in the values, then:
#
#   npm install
#   npm run db:setup     # create the Neon schema (once)
#   npm run dev
#
# ── Server-only (NOT exposed to the browser) ──────────────────────────────
# Neon/Postgres connection string. Used by the /api serverless functions and by
# the Vite dev middleware. Keep this secret.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Shared key the API requires in the `x-app-key` header. Leave blank to run the
# API open (fine for local dev). Set a value in production.
APP_API_KEY=

# ── Client (shipped in the browser bundle) ────────────────────────────────
# Must equal APP_API_KEY so the frontend can call the API. NOTE: because this
# ships to the browser it is a basic gate, not real auth — do not reuse a secret
# here that protects anything else.
VITE_APP_API_KEY=
# ──────────────────────────────────────────────────────────────────────────
