# ──────────────────────────────────────────────────────────────────────────
# MCCIA Intern OS — environment configuration
#
# Copy this to `.env.local` (gitignored — never commit real credentials) and
# fill in the values, then:
#
#   npm install
#   npm run db:setup     # create the Neon schema (once)
#   npm run dev
#
# ── Server-only (NOT exposed to the browser) ──────────────────────────────
# Supabase Postgres connection string. Used by the /api serverless functions and
# the Vite dev middleware. Keep this secret. Use the "Connection pooling" URI
# from Supabase → Project Settings → Database (Transaction mode, port 6543), e.g.
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# A long random secret (e.g. `openssl rand -base64 32`) that signs the session
# token (JWT in an HttpOnly cookie). Keep it stable across deploys and secret.
# `BETTER_AUTH_SECRET` is still accepted as a fallback for older deployments.
AUTH_SECRET=
# ──────────────────────────────────────────────────────────────────────────
